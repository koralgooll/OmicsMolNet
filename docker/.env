# Local-only admin bootstrap values for the Flowise init job.
#
# Copy from `docker/.env.example` and fill in the credentials.
# If you leave these values empty, the init job will skip bootstrapping.

FLOWISE_ADMIN_NAME=cezary
FLOWISE_ADMIN_EMAIL=cezary.turek@gmail.com
FLOWISE_ADMIN_PASSWORD=Cezary123!

# Optional (enterprise only):
FLOWISE_ORG_NAME=OmicsMolNet

# Optional override:
# FLOWISE_API_BASE_URL=http://flowise:3000
