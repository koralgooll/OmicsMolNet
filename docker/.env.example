# Copy this file to `docker/.env` and fill in the values.
#
# These settings are used by `docker/init-flowise.py` to auto-create the initial
# Flowise admin account, so you don't get redirected to `/organization-setup`
# on first run.

FLOWISE_ADMIN_NAME=Flowise Admin
FLOWISE_ADMIN_EMAIL=admin@example.com
FLOWISE_ADMIN_PASSWORD=ChangeMeNow_UseAStrongPassword123!

# Optional: only needed for enterprise licensed mode.
FLOWISE_ORG_NAME=Acme

# Optional override for the init script (defaults to the internal Docker DNS name).
# FLOWISE_API_BASE_URL=http://flowise:3000

